# Lemory needs exactly ONE of these keys to run.
GEMINI_API_KEY=your-gemini-api-key       # free-tier key from https://aistudio.google.com works
# OPENAI_API_KEY=sk-...                  # or run on OpenAI (provider auto-detects)

# Optional overrides (defaults shown) — full list in src/lemory/config.py
# LEMORY_VAULT=~/Documents/MyObsidianVault
# LEMORY_PROVIDER=auto                   # auto | gemini | openai
# LEMORY_LLM_MODEL=gemini-2.5-flash
# LEMORY_EMBED_MODEL=gemini-embedding-001
# LEMORY_EMBED_DIM=768
# LEMORY_QUERY_EXPANSION=false           # qmd-style LLM query expansion
# LEMORY_RERANK=false                    # qmd-style LLM rerank
# LEMORY_ENRICH_ENTITIES=false           # cognee-style LLM entity graph
