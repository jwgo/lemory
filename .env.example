# Lemory needs exactly one key to run: a Google Gemini API key (free tier works).
GEMINI_API_KEY=your-gemini-api-key

# Optional overrides (defaults shown)
# LEMORY_VAULT=~/Documents/MyObsidianVault
# LEMORY_LLM_MODEL=gemini-2.5-flash
# LEMORY_EMBED_MODEL=gemini-embedding-001
# LEMORY_EMBED_DIM=768
