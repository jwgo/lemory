benchmarks/data/maple_real/vault/
benchmarks/data/longmemeval/
benchmarks/data/dmr/msc_self_instruct.jsonl

# omnisearch bench harness deps (npm i minisearch in benchmarks/)
benchmarks/node_modules/
benchmarks/package-lock.json

